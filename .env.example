# EXPO_PUBLIC_DAEMON_GPU_PROFILE=mali_vulkan
# Optional: llama.cpp -ngl cap (1–99). Omit for default 99 (full offload when the driver supports it).
# EXPO_PUBLIC_DAEMON_FABRIC_GPU_LAYERS=99
