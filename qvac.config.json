{
  "loggerConsoleOutput": true,
  "loggerLevel": "debug",
  "deviceDefaults": [
    {
      "name": "Android safe LLM tuning defaults",
      "match": {
        "platform": "android"
      },
      "defaults": {
        "llm": {
          "temp": 0.12,
          "top_p": 0.78,
          "top_k": 32,
          "repeat_penalty": 1.16
        }
      }
    },
    {
      "name": "Mali Vulkan safe defaults",
      "match": {
        "platform": "android",
        "deviceBrand": "OnePlus"
      },
      "defaults": {
        "llm": {
          "device": "gpu",
          "gpu_layers": 16,
          "temp": 0.12,
          "top_p": 0.78
        }
      }
    }
  ],
  "plugins": [
    "@qvac/sdk/llamacpp-completion/plugin",
    "@qvac/sdk/llamacpp-embedding/plugin",
    "@qvac/sdk/whispercpp-transcription/plugin",
    "@qvac/sdk/onnx-ocr/plugin"
  ]
}
